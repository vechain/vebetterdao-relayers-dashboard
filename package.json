    "i18next-resources-to-backend": "^1.2.1",
    "next": "14.2.35",
    "next-themes": "^0.4.6",
    "react": "^18",
    "react-dom": "^18",
    "react-i18next": "^16.5.6",
    "react-icons": "^5.5.0",
    "recharts": "^3.7.0"
