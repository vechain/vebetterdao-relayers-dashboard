    "@tanstack/query-sync-storage-persister": "^5.28.12",
    "@tanstack/react-query": "^5.64.2",
    "@tanstack/react-query-persist-client": "^5.28.12",
    "@use-gesture/react": "^10.3.1",
    "@vechain/vebetterdao-contracts": "8.4.0",
    "@vechain/vebetterdao-relayer-node": "1.1.0",
    "@vechain/vechain-kit": "^2.6.9",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "i18next": "^25.8.17",
