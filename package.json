    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vechain/sdk-core": "^2.0.7",
    "@vechain/sdk-network": "^2.0.7",
    "eslint": "^8",
    "eslint-config-next": "14.2.25",
    "eslint-plugin-react-hooks": "^4.6.0",
    "ts-node": "^10.9.2",
    "typescript": "^5"
