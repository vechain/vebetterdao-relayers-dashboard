    "dev": "NEXT_PUBLIC_APP_ENV=mainnet next dev --turbo -p 3001",
    "dev:staging": "NEXT_PUBLIC_APP_ENV=testnet-staging next dev --turbo -p 3001",
    "dev:mainnet": "NEXT_PUBLIC_APP_ENV=mainnet next dev --turbo -p 3001",
    "build": "yarn chakra:typegen && next build",
    "build:staging": "NEXT_PUBLIC_APP_ENV=testnet-staging yarn build",
    "build:mainnet": "NEXT_PUBLIC_APP_ENV=mainnet yarn build",
    "start": "next start",
    "lint": "next lint",
    "analyze-auto-voting": "ts-node scripts/analyzeAutoVotingRounds.ts"
  },
  "dependencies": {
    "@chakra-ui/react": "3.30.0",
